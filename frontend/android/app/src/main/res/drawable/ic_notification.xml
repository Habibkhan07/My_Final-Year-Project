<!--
    Status-bar notification icon for FCM messages. Referenced from
    AndroidManifest.xml via:
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />

    Constraint (Android API 21+): the status-bar treats this as an
    alpha-only mask — every non-transparent pixel renders as solid white,
    every fillColor is ignored at the status-bar level. The accent color
    (visible in the notification body) comes from
    @color/notification_color via the sibling default_notification_color
    meta-data.

    Vector chosen over raster to avoid 5x density variants. Replace the
    pathData with the brand glyph when design provides it; the current
    shield silhouette is a placeholder.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,2L4,5v6.09c0,5.05 3.41,9.76 8,10.91 4.59,-1.15 8,-5.86 8,-10.91L20,5l-8,-3z" />
</vector>
