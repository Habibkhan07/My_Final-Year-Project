<?xml version="1.0" encoding="utf-8"?>
<!--
    notification_color — accent applied to the notification body and the
    small icon's monochrome backdrop. Referenced from AndroidManifest.xml
    via:
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />

    Matches AppColors.primary (lib/core/theme/app_colors.dart) — the Karigar
    brand blue used by every primary CTA. Keep this in sync when the brand
    primary changes; an Android resource value cannot reference the Dart
    constant directly.
-->
<resources>
    <color name="notification_color">#004AC6</color>
</resources>
