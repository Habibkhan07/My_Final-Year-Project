# Example .env — copy to backend/.env and fill in real values.
# This file is committed; the real .env is gitignored.

# --- Django core ---
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=fyp_marketplace
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Redis (Channels DB 0, Celery DB 1) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Twilio (production OTP; trial blocks Pakistan SMS so DEBUG=True keeps OTP=123456) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=
TWILIO_TEST_FROM_NUMBER=+15005550006

# --- Firebase (FCM) ---
FIREBASE_CREDENTIALS_PATH=

# --- Celery (defaults derived from REDIS_HOST/PORT if unset) ---
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- Booking orchestrator ---
# False (default): manual `arrived` endpoint warns on geofence mismatch but allows.
# True: rejects with 400 not_at_customer_location when current_lat/lng are >100m
# from the customer's address. Auto path is unaffected.
BOOKING_GEOFENCE_STRICT=False
